rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "ident@aviationonline.fr" ||
              request.auth.token.email == "server@aviationonline.fr" ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Rules
    match /_health_check_/{docId} {
      allow read, write: if true;
    }

    match /test/{docId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /modules/{moduleId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /courses/{courseId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /connection_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /questions/{questionId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /quiz_attempts/{attemptId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
